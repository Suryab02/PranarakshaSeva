MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/pranarakshaseva

# Random secret used to sign admin session tokens. Strongly recommended in
# production: if unset on Vercel the app still runs, but signs with a random
# per-instance secret, so admins get logged out as instances cycle.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Operator-only secret for minting blood-bank admin invites via
# POST /api/auth/invite. If unset, invite creation is disabled.
ADMIN_INVITE_SECRET=

# Comma-separated list of allowed CORS origins (optional; defaults to localhost).
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Guards re-seeding once the database already has data.
# SEED_KEY=
